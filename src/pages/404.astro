---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Not Found">
  <div class="not-found">
    <div class="not-found-inner">
      <span class="not-found-code">404</span>
      <h1>Page not found.</h1>
      <p>The page you're looking for doesn't exist. This site has one page — <a href="/">go there</a>.</p>
    </div>
  </div>
</Base>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 56px;
  }

  .not-found-inner {
    text-align: center;
    max-width: 480px;
  }

  .not-found-code {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 16px;
  }

  h1 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 48px;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  p {
    font-size: 15px;
    color: var(--ink-2);
    line-height: 1.6;
  }

  a {
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
  }

  a:hover { opacity: 0.6; }
</style>
