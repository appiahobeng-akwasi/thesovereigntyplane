    &ldquo;Publishing a strategy is cheap. Building an institution that can enforce against a hyperscaler is not.&rdquo;
  </aside>

  <div class="hero-scroll">Scroll</div>
</section>

<style>
  .hero {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 56px;
    min-height: 100vh;
    padding-top: 140px;
    padding-bottom: 80px;
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 320px;
    gap: 56px;
    align-items: start;
    position: relative;
  }

  .hero-meta {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.03em;
    padding-top: 24px;
  }

  .hero-meta-item { margin-bottom: 24px; }

  .hero-meta-label {
    display: block;
    color: var(--ink-mute);
    margin-bottom: 6px;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.08em;
  }

  .hero-meta-value {
    display: block;
    color: var(--ink-2);
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    letter-spacing: normal;
    text-transform: none;
    line-height: 1.5;
  }

  .hero-main h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    font-size: clamp(56px, 7.4vw, 118px);
    line-height: 0.94;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 48px;
  }

  .hero-main h1 .it {
    font-style: italic;
  }

  .hero-sub {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--ink-2);
    line-height: 1.6;
    max-width: 520px;
    letter-spacing: -0.003em;
  }

  .hero-aside {
    padding-top: 24px;
    font-family: 'Instrument Serif', serif;
    font-size: 20px;
    font-style: italic;
    line-height: 1.45;
    color: var(--ink-2);
    max-width: 320px;
    letter-spacing: -0.005em;
  }

  .hero-aside::before {
    content: '';
    display: block;
    width: 36px;
    height: 1px;
    background: var(--ink);
    margin-bottom: 18px;
  }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 56px;
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-scroll::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--ink-mute);
  }

  @media (max-width: 1100px) {
    .hero {
      padding-left: 32px;
      padding-right: 32px;
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
