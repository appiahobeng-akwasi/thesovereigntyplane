<section class="contact" id="contact">
  <div class="contact-inner">
    <span class="contact-section-label">&sect;06 &middot; Contact</span>
    <div class="contact-body">
      <p class="contact-text">The best way to reach me is <em>directly.</em> <a href="mailto:appiahk4@gmail.com" class="contact-email">appiahk4@gmail.com</a></p>
      <div class="contact-channels">
        <a href="https://wa.me/233500008307" target="_blank" rel="noopener" class="contact-link">WhatsApp &rarr;</a>
        <a href="https://linkedin.com/in/akwasi-appiah-obeng" target="_blank" rel="noopener" class="contact-link">LinkedIn &rarr;</a>
        <a href="/papers/cv.pdf" class="contact-link">Download CV &rarr;</a>
        <a href="/papers/negotiating-intelligence.pdf" class="contact-link">Download Negotiating Intelligence &rarr;</a>
      </div>
      <p class="contact-alt-phone">Also reachable on <a href="https://wa.me/23280266124" class="contact-email">+232 80 266 124</a></p>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .contact {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 56px;
    padding-top: 120px;
    padding-bottom: 120px;
    border-top: 1px solid var(--rule);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 56px;
  }

  /* ── Section label ── */
  .contact-section-label {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 6px;
  }

  /* ── Body ── */
  .contact-body {
    max-width: 640px;
  }

  .contact-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--ink-2);
    line-height: 1.6;
    letter-spacing: -0.003em;
    margin-bottom: 32px;
  }

  .contact-text em {
    font-style: italic;
  }

  .contact-email {
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    transition: border-color 180ms;
  }

  .contact-email:hover {
    border-bottom-color: var(--ink);
  }

  .contact-alt-phone {
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    color: var(--ink-mute);
    margin-top: 16px;
  }

  /* ── Channels ── */
  .contact-channels {
    display: flex;
    gap: 36px;
  }

  .contact-link {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    color: var(--ink-2);
    letter-spacing: 0.03em;
    transition: color 180ms;
  }

  .contact-link:hover {
    color: var(--ink);
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .contact {
      padding-left: 32px;
      padding-right: 32px;
      padding-top: 80px;
      padding-bottom: 80px;
    }

    .contact-inner {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  @media (max-width: 680px) {
    .contact-channels {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
