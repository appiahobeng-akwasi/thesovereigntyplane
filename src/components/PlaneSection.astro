---
import type { Country } from '../data/types';
import PlaneIsland from './PlaneIsland.tsx';

interface Props {
  countries: Country[];
}

const { countries } = Astro.props;
---

<section class="plane-section" id="plane">
  <div class="plane-header">
    <div class="sec-label">
      <span class="sec-label-num">&sect;01 &middot; The Flagship</span>
      <span class="sec-label-name">The Plane</span>
    </div>
    <div>
      <h2 class="plane-title">A diagnostic<br />for the <span class="it">gap.</span></h2>
      <p class="plane-lede">Most analyses of African AI governance count strategies, laws, and signed declarations. This is a two-dimensional instrument for measuring whether the institutions behind those declarations can actually do anything — applied to fifteen African states across forty-four indicators.</p>
    </div>
  </div>

  <PlaneIsland countries={countries} client:visible />
</section>

<style>
  .plane-section {
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 56px;
    position: relative;
  }

  .plane-header {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 56px;
    margin-bottom: 72px;
  }

  .sec-label {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 16px;
  }

  .sec-label-num {
    display: block;
    color: var(--ink-mute);
    margin-bottom: 10px;
    font-size: 10px;
  }

  .sec-label-name {
    display: block;
    font-family: 'Instrument Serif', serif;
    font-size: 28px;
    font-style: italic;
    color: var(--ink);
    text-transform: none;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .plane-title {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: clamp(48px, 6.4vw, 96px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }

  .plane-title .it { font-style: italic; }

  .plane-lede {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 22px;
    line-height: 1.45;
    color: var(--ink-2);
    max-width: 640px;
    letter-spacing: -0.005em;
  }

  @media (max-width: 1100px) {
    .plane-section { padding-left: 32px; padding-right: 32px; }
    .plane-header {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
