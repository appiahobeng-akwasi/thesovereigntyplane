---
---

<div class="hero-image">
  <div class="hero-image-inner">
    <div class="hero-image-placeholder">
      <div class="hero-image-placeholder-title">[ hero photograph ]</div>
      <div>dark cinematic image &middot; subsea cable landing, cabinet workshop, or similar</div>
    </div>
  </div>
</div>

<style>
  .hero-image {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 56px;
    margin-top: 32px;
    margin-bottom: 120px;
  }

  .hero-image-inner {
    position: relative;
    width: 100%;
    height: 56vh;
    min-height: 420px;
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2420 50%, #1a1a1a 100%);
    overflow: hidden;
  }

  .hero-image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 12px;
    color: rgba(255, 255, 255, 0.4);
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-image-placeholder-title {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 22px;
    color: rgba(255, 255, 255, 0.7);
    text-transform: none;
    letter-spacing: normal;
  }

  @media (max-width: 1100px) {
    .hero-image { padding-left: 32px; padding-right: 32px; }
  }
</style>
