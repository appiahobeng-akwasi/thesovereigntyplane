---
---

<div class="hero-image">
  <div class="hero-image-inner">
    <img
      src="/images/hero.jpg"
      alt="Technicians working at a subsea cable landing station on the African coast — where formal infrastructure meets substantive capacity"
      width="1920"
      height="1279"
      loading="eager"
      decoding="async"
    />
  </div>
</div>

<style>
  .hero-image {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 56px;
    margin-top: 32px;
    margin-bottom: 120px;
  }

  .hero-image-inner {
    position: relative;
    width: 100%;
    height: 56vh;
    min-height: 420px;
    overflow: hidden;
    background: #1a1a1a;
  }

  .hero-image-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  @media (max-width: 1100px) {
    .hero-image { padding-left: 32px; padding-right: 32px; }
  }

  @media (max-width: 600px) {
    .hero-image { padding-left: 16px; padding-right: 16px; }
    .hero-image-inner { min-height: 280px; height: 40vh; }
  }
</style>
