---
const workItems = [
  {
    dates: '2025 — now',
    org: 'Tony Blair Institute for Global Change',
    logo: '/logos/tbi.svg',
    logoHasText: false,
    url: 'https://institute.global',
    role: 'Manager, Technology and Innovation',
    description:
      'Leading Sierra Leone\u2019s National AI Strategy, National Data Governance Strategy, and National Digital Development Bill. Lead technical advisor to the Ministry of Communications on a $50M World Bank Digital Transformation Project. Trained the Sierra Leonean Cabinet and 500+ civil servants alongside MIT and Qhala.',
    location: 'Freetown, Sierra Leone',
  },
  {
    dates: 'Aug — Dec 2025',
    org: 'Sand Technologies',
    logo: '/logos/sand-technologies.png',
    logoHasText: false,
    url: 'https://www.sandtech.com',
    role: 'Consultant — National Health Information Hub',
    description:
      'Led end-to-end discovery, requirements, stakeholder alignment, and design of Sierra Leone\u2019s Ministry of Health National Health Information Hub, from inception to launch in four months. Defined data architecture aligned to national health data standards.',
    location: 'Freetown, Sierra Leone',
  },
  {
    dates: '2023 — 2025',
    org: 'Medtronic Labs',
    logo: '/logos/medtronic-labs.svg',
    logoHasText: true,
    url: 'https://www.medtroniclabs.org',
    role: 'Senior Programmes Lead',
    description:
      'Directed a multi-country digital health programme across Kenya, Ghana, Sierra Leone, and Tanzania. Improved healthcare access for 150,000+ underserved patients; achieved 60% improved health outcomes for nearly 100,000 enrolled patients \u2014 more than double the national baseline.',
    location: 'Four countries, East & West Africa',
  },
  {
    dates: '2021 — 2022',
    org: 'GIZ',
    logo: '/logos/giz.svg',
    logoHasText: true,
    url: 'https://www.giz.de',
    role: 'Senior Technical Advisor — Digital Transformation & PPP',
    description:
      'Managed a \u20AC12M Innovation Fund supporting public-private digital health initiatives. Advised the Ghana Health Service on the adoption of AI-driven health solutions during the COVID-19 response. Funded the Locovent, a low-cost ventilator deployed at national scale.',
    location: 'Accra, Ghana',
  },
  {
    dates: '2016 — 2021',
    org: 'Delft Imaging',
    logo: '/logos/delft-imaging.svg',
    logoHasText: true,
    url: 'https://delftimaging.com',
    role: 'Project Manager — Africa',
    description:
      'Managed deployment of AI-driven TB diagnostic hardware (CAD4TB) across nine Sub-Saharan African countries. Owned donor reporting for WHO, USAID, FHI 360, and the Global Fund. Navigated regulatory approvals across multiple jurisdictions.',
    location: 'Nine countries, Sub-Saharan Africa',
  },
];
---

<section class="work" id="work">
  <div class="work-grid">
    <div class="work-label">
      <span class="section-tag">&sect;04 / Work</span>
    </div>
    <div class="work-content">
      <h2>Ten years <em>inside</em> African digital transformation.</h2>
      <p class="work-lede">
        The Sovereignty Plane is a theoretical instrument. It was written because the practitioner experience below made the gap impossible to unsee.
      </p>

      <ol class="work-list">
        {workItems.map((item) => (
          <li class="work-item">
            <span class="work-item-dates">{item.dates}</span>
            <div class="work-item-body">
              <div class="work-item-org-row">
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="work-item-logo-link">
                  <img
                    src={item.logo}
                    alt={`${item.org} logo`}
                    class:list={['work-item-logo', { 'work-item-logo--wordmark': item.logoHasText }]}
                    loading="lazy"
                  />
                </a>
                {!item.logoHasText && <h3 class="work-item-org">{item.org}</h3>}
              </div>
              <p class="work-item-role">{item.role}</p>
              <p class="work-item-desc">{item.description}</p>
            </div>
            <span class="work-item-location">{item.location}</span>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  /* ── Section container ── */
  .work {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 56px;
    padding-top: 120px;
    padding-bottom: 120px;
  }

  /* ── 2-column: 240px label rail + content ── */
  .work-grid {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 56px;
  }

  /* ── Label rail ── */
  .section-tag {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    position: sticky;
    top: 100px;
  }

  /* ── Heading ── */
  .work-content h2 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    font-size: clamp(36px, 4.2vw, 60px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .work-content h2 em {
    font-style: italic;
  }

  /* ── Lede paragraph ── */
  .work-lede {
    font-family: 'Inter Variable', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--ink-2);
    line-height: 1.6;
    max-width: 640px;
    margin-bottom: 64px;
    letter-spacing: -0.003em;
  }

  /* ── Work list ── */
  .work-list {
    list-style: none;
  }

  /* ── Individual work item: 3-column grid ── */
  .work-item {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr) 220px;
    gap: 32px;
    padding-top: 28px;
    padding-bottom: 28px;
    border-top: 1px solid var(--rule);
    align-items: start;
  }

  .work-item:last-child {
    border-bottom: 1px solid var(--rule);
  }

  /* ── Dates column ── */
  .work-item-dates {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.03em;
    line-height: 1.6;
    padding-top: 2px;
    white-space: nowrap;
  }

  /* ── Body column ── */
  .work-item-org-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }

  .work-item-logo-link {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .work-item-logo {
    height: 22px;
    width: auto;
    max-width: 100px;
    object-fit: contain;
    flex-shrink: 0;
    opacity: 0.7;
    filter: grayscale(1);
    transition: opacity 200ms, filter 200ms;
  }

  /* Wordmark logos (contain the company name) — render larger since text is hidden */
  .work-item-logo--wordmark {
    height: 26px;
    max-width: 140px;
  }

  .work-item:hover .work-item-logo,
  .work-item-logo-link:hover .work-item-logo {
    opacity: 1;
    filter: grayscale(0);
  }

  .work-item-org {
    font-family: 'Inter Variable', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .work-item-role {
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-3);
    line-height: 1.4;
    margin-bottom: 12px;
    letter-spacing: -0.003em;
  }

  .work-item-desc {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--ink-2);
    line-height: 1.6;
    letter-spacing: -0.003em;
    max-width: 560px;
  }

  /* ── Location column ── */
  .work-item-location {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.03em;
    line-height: 1.6;
    text-align: right;
    padding-top: 2px;
  }

  /* ── Responsive: collapse at 1100px ── */
  @media (max-width: 1100px) {
    .work {
      padding-left: 32px;
      padding-right: 32px;
    }

    .work-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .section-tag {
      position: static;
    }

    .work-item {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .work-item-dates {
      order: 0;
    }

    .work-item-body {
      order: 1;
    }

    .work-item-location {
      order: 2;
      text-align: left;
      padding-top: 4px;
    }
  }
</style>
