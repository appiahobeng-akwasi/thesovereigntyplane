---
import '@fontsource/instrument-serif';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import '../styles/plane.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Sovereignty Plane — Formal vs. Substantive AI Sovereignty in Africa',
  description = 'A diagnostic for the gap between what African states declare about AI governance and what they can actually do. Nineteen countries, 836 indicators. A research instrument from the working paper Negotiating Intelligence.',
} = Astro.props;

const canonicalURL = 'https://thesovereigntyplane.report/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${canonicalURL}images/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonicalURL}images/og-image.jpg`} />

    <meta name="theme-color" content="#fafaf9" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <a class="skip-to-content" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
