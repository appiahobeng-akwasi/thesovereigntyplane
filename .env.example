# Public — safe to embed in client bundles
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ... # the read-only anon key

# Private — server-side only, never exposed to client
SUPABASE_SERVICE_ROLE_KEY=eyJ... # full access, used by seed script only
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/... # the webhook Supabase calls to trigger rebuilds
SENTRY_DSN=https://...@sentry.io/... # optional, for error monitoring

# Public site config
PUBLIC_SITE_URL=https://thesovereigntyplane.report
